{
  "dfx": "0.17.0",
  "canisters": {
    "orchestrator": {
      "type": "rust",
      "package": "orchestrator",
      "candid": "./.artifact/orchestrator.did",
      "declarations": {
        "node_compatibility": true
      }
    },
    "usercan": {
      "type": "rust",
      "package": "usercan",
      "candid": "./.artifact/usercan.did",
      "declarations": {
        "node_compatibility": true
      }
    },
    "frontend": {
      "build": "pnpm --filter frontend run build",
      "dependencies": ["orchestrator", "usercan"],
      "source": ["frontend/build/"],
      "type": "assets"
    },
    "marketing": {
      "build": "pnpm --filter landing-page run build",
      "dependencies": ["frontend"],
      "source": ["landing-page/dist/"],
      "type": "assets"
    },
    "internet_identity": {
      "type": "pull",
      "id": "rdmx6-jaaaa-aaaaa-aaadq-cai"
    }
  },
  "defaults": {
    "build": {
      "packtool": ""
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:8000",
      "type": "ephemeral"
    }
  },
  "version": 1
}
